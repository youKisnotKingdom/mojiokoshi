# ============================================================
# Mojiokoshi 環境変数設定例
# このファイルを .env にコピーして値を編集してください
# cp .env.example .env
# ============================================================

# 【必須】秘密鍵 - 以下コマンドで生成してください:
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# 【必須】初回起動時に作成する管理者アカウント
# 一度作成されたら以降は削除して構いません
ADMIN_USER_ID=000001
ADMIN_PASSWORD=ChangeMe123

# PostgreSQL パスワード（デフォルト: mojiokoshi）
POSTGRES_PASSWORD=mojiokoshi

# アプリ公開ポート（デフォルト: 8000）
APP_PORT=8000

# ============================================================
# LLM（要約機能）設定
# llama.cpp / Ollama など OpenAI 互換 API のエンドポイントを指定
# ============================================================

# LLM API エンドポイント（例: 同一サーバーで Ollama を動かす場合）
LLM_API_BASE_URL=http://host.docker.internal:11434/v1

# LLM API キー（不要な場合は空欄のまま）
LLM_API_KEY=

# 使用するモデル名
LLM_MODEL_NAME=default

# ============================================================
# Whisper（文字起こし）設定
# ============================================================

# モデルサイズ: tiny / base / small / medium / large
# GPU なし環境では small または medium を推奨（large は遅い）
WHISPER_MODEL_SIZE=large

# 使用デバイス: cpu または cuda（NVIDIA GPU がある場合）
WHISPER_DEVICE=cpu

# 音声ファイルの保持日数（この日数を超えたファイルは自動削除）
AUDIO_RETENTION_DAYS=30
