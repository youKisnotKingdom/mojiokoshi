# ============================================================
# Mojiokoshi 環境変数設定例
# このファイルを .env にコピーして値を編集してください
# cp .env.example .env
# ============================================================

# 【必須】秘密鍵 - 以下コマンドで生成してください:
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# 【必須】初回起動時に作成する管理者アカウント
# 一度作成されたら以降は削除して構いません
ADMIN_USER_ID=000001
ADMIN_PASSWORD=ChangeMe123

# PostgreSQL パスワード（デフォルト: mojiokoshi）
POSTGRES_PASSWORD=mojiokoshi

# アプリ公開ポート（HTTP、デフォルト: 8000）
APP_PORT=8000

# チェッカーデモアプリのポート（HTTP、デフォルト: 8001）
CHECKER_PORT=8001

# 音声アップロード上限（bytes）
# 1GB = 1073741824 / 2GB = 2147483648
# Docker 構成のデフォルトは 1GB
# MAX_UPLOAD_SIZE=1073741824

# nginx 側のアップロード上限
# `MAX_UPLOAD_SIZE` と揃えてください
# 1GB = 1g / 2GB = 2g
# NGINX_CLIENT_MAX_BODY_SIZE=1g

# HTTPS ポート（docker-compose.https.yml 使用時、デフォルト: 443）
# 443 が使えない場合は 8443 などに変更
# HTTPS_PORT=8443

# チェッカーデモアプリの HTTPS ポート（デフォルト: 8444）
# マイク使用のため HTTPS が必要
# CHECKER_HTTPS_PORT=8444

# ============================================================
# LLM（要約機能）設定
# llama.cpp / Ollama など OpenAI 互換 API のエンドポイントを指定
# ============================================================

# LLM API エンドポイント（例: 同一サーバーで Ollama を動かす場合）
LLM_API_BASE_URL=http://host.docker.internal:11434/v1

# LLM API キー（不要な場合は空欄のまま）
LLM_API_KEY=

# 使用するモデル名
LLM_MODEL_NAME=default

# ============================================================
# Whisper（文字起こし）設定
# ============================================================

# モデルサイズ: tiny / base / small / medium / large
# GPU なし環境では small または medium を推奨（large は遅い）
WHISPER_MODEL_SIZE=large
DEFAULT_TRANSCRIPTION_ENGINE=parakeet_ja

# web 側の使用デバイス: 通常は cpu のままにして batch と分離
WEB_WHISPER_DEVICE=cpu

# worker 側の使用デバイス: NVIDIA GPU がある場合は cuda を推奨
WORKER_WHISPER_DEVICE=cuda

# 音声ファイルの保持日数（この日数を超えたファイルは自動削除）
AUDIO_RETENTION_DAYS=30

# リアルタイム録音 UI を有効化するか（本番では false 推奨）
ENABLE_REALTIME_TRANSCRIPTION=false

# worker のポーリング間隔（秒）
WORKER_POLL_INTERVAL=5

# worker が同時に処理する文字起こしジョブ数
WORKER_TRANSCRIPTION_CONCURRENCY=1

# worker が同時に処理する要約ジョブ数
WORKER_SUMMARY_CONCURRENCY=1

# PROCESSING のまま残った stale job を再キューするまでの秒数
# 実際の最大処理時間より十分長くしてください
WORKER_TRANSCRIPTION_STALE_TIMEOUT_SECONDS=3600
WORKER_SUMMARY_STALE_TIMEOUT_SECONDS=1800

# checker デモは GPU 競合を避けるため CPU を推奨
CHECKER_WHISPER_DEVICE=cpu
CHECKER_WHISPER_LANGUAGE=ja
