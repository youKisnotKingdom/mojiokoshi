# Application
APP_NAME=Mojiokoshi
DEBUG=true
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql://mojiokoshi:mojiokoshi@localhost:5432/mojiokoshi

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=524288000

# Audio Cleanup
AUDIO_RETENTION_DAYS=30

# LLM API (Local network server)
LLM_API_BASE_URL=http://192.168.1.100:8000/v1
LLM_API_KEY=
LLM_MODEL_NAME=mistral-7b
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# Transcription
WHISPER_MODEL_SIZE=large
WHISPER_DEVICE=cuda
